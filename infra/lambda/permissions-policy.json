{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:*:*:*"
    },
    {
      "Sid": "VaultBucketReadWrite",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::resqd-vault-64553a1a",
        "arn:aws:s3:::resqd-vault-64553a1a/*"
      ]
    },
    {
      "Sid": "AuthTables",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:Query"
      ],
      "Resource": [
        "arn:aws:dynamodb:us-east-1:465457334560:table/resqd-users",
        "arn:aws:dynamodb:us-east-1:465457334560:table/resqd-users/index/*",
        "arn:aws:dynamodb:us-east-1:465457334560:table/resqd-auth-challenges",
        "arn:aws:dynamodb:us-east-1:465457334560:table/resqd-api-tokens",
        "arn:aws:dynamodb:us-east-1:465457334560:table/resqd-api-tokens/index/*"
      ]
    }
  ]
}
